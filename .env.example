# ─── REQUIRED ─────────────────────────────────────────────────────────────────

# Groq API key — used for all AI scraping and chat capabilities
# Get free key: https://console.groq.com
GROQ_API_KEY=""

# Gemini API key — used for structured itineraries, scraping, and chat fallback
# Get key: https://aistudio.google.com
GEMINI_API_KEY=""

# OpenRouter API key — used for Claude 3.5 Sonnet integrations
# Get key: https://openrouter.ai
OPENROUTER_API_KEY=""

# ─── IMAGES (pick one or both — fallback chain: Pexels → Wikipedia → Scenic) ──

# Pexels API — free, no rate-limit issues, no CORS problem
# Get free key: https://www.pexels.com/api/
PEXELS_API_KEY=""

# Unsplash — optional, kept for fallback if you already have a key
# Get key: https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=""

# ─── APP ──────────────────────────────────────────────────────────────────────
# Application URL for OpenRouter Referer headers
APP_URL=""
